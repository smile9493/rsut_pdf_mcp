# PDF Module Configuration

# Server settings
PDF_SERVER_HOST=0.0.0.0
PDF_SERVER_PORT=8000
PDF_SERVER_DEBUG=false

# API prefix
API_URL_PREFIX=/api/v1

# Logging
PDF_LOG_LEVEL=INFO
# PDF_LOG_FILE=/var/log/pdf-module/server.log

# File limits
PDF_MAX_FILE_SIZE_MB=200

# Default extraction adapter (pdfplumber or pymupdf)
PDF_DEFAULT_ADAPTER=pymupdf

# Cache settings
PDF_CACHE_ENABLED=true
PDF_CACHE_MAX_SIZE=100
PDF_CACHE_TTL_SECONDS=3600
