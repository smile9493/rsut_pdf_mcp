# ==================== Git Repository Info ====================
# This is the root .gitignore for a multi-project monorepo
# Contains: pdf-module-rs (Rust), pdf-web-ui (Web), unstract (Reference)

# ==================== Rust - Build Artifacts ====================
# Note: target/ is ignored in pdf-module-rs/.gitignore
**/*.rs.bk           # Rust backup files
*.pdb                # Debug symbols

# Root-level compiled binaries (use leading / to avoid matching subdirectories)
/pdf-mcp
/pdf-rest

# ==================== Python ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pylintrc

# ==================== Environment & Secrets ====================
.env
.env.local
.env.*.local
*.env
*.pem
*.key
*.crt
secrets/
.secrets/

# ==================== IDE & Editors ====================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# ==================== Operating System ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ==================== Logs ====================
*.log
logs/
*.log.*

# ==================== Data & Cache ====================
data/
cache/
*.cache
.npm/
.yarn/

# ==================== Docker ====================
.docker/

# ==================== Build Artifacts ====================
# PDF files (except documentation and test fixtures)
*.pdf
*.PDF
!docs/**/*.pdf
!**/tests/fixtures/**/*.pdf
!**/test_data/**/*.pdf

# Archives (except release artifacts)
*.zip
*.tar.gz
*.tgz
*.rar
!.github/releases/**

# ==================== Temporary Files ====================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# ==================== Database ====================
*.db
*.sqlite
*.sqlite3

# ==================== Jupyter Notebooks ====================
.ipynb_checkpoints/

# ==================== Node.js ====================
node_modules/

# ==================== Tool-specific ====================
.arts/
.codeartsdoer/

# ==================== Reference Projects ====================
# unstract is a reference project, not part of our codebase
unstract/
