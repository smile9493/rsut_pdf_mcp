FROM alpine:3.19

RUN apk add --no-cache ca-certificates libgcc

COPY pdf-rest /usr/local/bin/pdf-rest

RUN adduser -D -s /bin/false pdfuser

ENV PDF_SERVER_HOST=0.0.0.0
ENV PDF_SERVER_PORT=8000
ENV PDF_DEFAULT_ADAPTER=lopdf
ENV PDF_CACHE_ENABLED=true
ENV PDF_MAX_FILE_SIZE_MB=200

EXPOSE 8000

USER pdfuser

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost:8000/api/v1/x2text/health || exit 1

ENTRYPOINT ["pdf-rest"]
