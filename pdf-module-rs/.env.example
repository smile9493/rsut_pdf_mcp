# PDF Module Rust Configuration
# Copy this file to .env and modify as needed

# === Server Configuration ===
SERVER_NAME=pdf-module-mcp
SERVER_VERSION=0.2.0
ENVIRONMENT=development

# === Storage Configuration ===
STORAGE_TYPE=local
LOCAL_STORAGE_BASE_DIR=./data

# S3 Storage Configuration (if STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Google Cloud Storage Configuration (if STORAGE_TYPE=gcs)
GCS_BUCKET=
GCS_CREDENTIALS_PATH=

# Azure Blob Storage Configuration (if STORAGE_TYPE=azure)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER=

# === Cache Configuration ===
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL_SECONDS=3600
CACHE_DIR=./cache

# === Audit Configuration ===
AUDIT_ENABLED=true
AUDIT_BACKEND=file
AUDIT_LOG_DIR=./logs/audit
AUDIT_RETENTION_DAYS=30

# Audit Database Backend (if AUDIT_BACKEND=database)
AUDIT_DB_CONNECTION_STRING=
AUDIT_DB_TABLE_NAME=audit_logs

# Audit Remote Backend (if AUDIT_BACKEND=remote)
AUDIT_REMOTE_ENDPOINT=
AUDIT_REMOTE_API_KEY=

# === Logging Configuration ===
LOG_LEVEL=info
LOG_FORMAT=json

# === Security Configuration ===
PATH_REQUIRE_ABSOLUTE=true
PATH_ALLOW_TRAVERSAL=false
PATH_BASE_DIR=./data
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf

# === MCP Configuration ===
MCP_TRANSPORT_MODE=stdio
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8080

# === REST API Configuration ===
REST_API_HOST=0.0.0.0
REST_API_PORT=8000
API_URL_PREFIX=/api/v1

# === Metrics Configuration ===
METRICS_ENABLED=true
METRICS_PORT=9090

# === Plugin Configuration ===
PLUGIN_DIR=./plugins
PLUGIN_HOT_RELOAD=false
